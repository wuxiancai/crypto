ENVIRONMENT=paper
EXECUTION_MODE=paper
# Database credentials. POSTGRES_PASSWORD is REQUIRED (docker-compose refuses to
# start without it) — set a strong, unique value and keep DATABASE_URL in sync.
POSTGRES_USER=crypto
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=crypto_quant
DATABASE_URL=postgresql+psycopg://crypto:change-me-to-a-strong-password@localhost:55432/crypto_quant
POSTGRES_PORT=55432
BINANCE_BASE_URL=https://fapi.binance.com
# Live mode requires this exact opt-in:
# LIVE_TRADING_CONFIRM=I_UNDERSTAND_THE_RISK
